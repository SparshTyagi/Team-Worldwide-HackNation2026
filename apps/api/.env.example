# Copy to .env and fill in (never commit .env).
# Revoke any key that was ever pasted into chat or committed.
# This file powers `node src/index.js` backend runtime.

OPENROUTER_API_KEY=
OPENROUTER_SERVER_LARGE_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_OFFER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTEROFFERMODEL=nvidia/nemotron-3-super-120b-a12b:free
# Server-side offer generation model only (intent should remain local/edge).
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
# Optional override
# ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1

# Backward-compatible alias (optional)
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

SUPABASE_URL=
SUPABASE_KEY=
TAVILY_API_KEY=

# Edge intent runtime (GDPR-safe defaults)
INTENT_MODEL_PROVIDER=onnx
INTENT_ONNX_MODEL_PATH=./packages/intent-engine/models/intent/intent_classifier.onnx
# Optional for non-default ONNX input tensor names
# INTENT_ONNX_INPUT_NAME=input
# Local small-model fallback if ONNX is unavailable
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_INTENT_MODEL=nemotron-3-nano:4b

# Optional
# PORT=8080
# HOST=0.0.0.0
