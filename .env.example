# Root env file for client/demo scripts.
# Copy to .env.local in the repository root.
# Backend runtime reads, in order:
# 1) apps/api/.env
# 2) root .env.local
# 3) root .env
OPENROUTER_API_KEY=replace_with_your_new_key
# Note: Comment out the proxy URL if running backend python scripts without the proxy running locally
OPENROUTER_PROXY_BASE_URL=http://localhost:8787
OPENROUTER_PROXY_SESSION_TOKEN=replace_with_session_token
OPENROUTER_PROXY_PORT=8787
OPENROUTER_OFFER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTEROFFERMODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_HTTP_REFERER=https://localhost
OPENROUTER_APP_TITLE=Generative City Wallet
OPENROUTER_ANALYTICS_MODEL=stepfun/step-3.5-flash
OPENROUTER_INTENT_MODEL=nvidia/nemotron-3-nano-4b
OPENROUTER_SERVER_LARGE_MODEL=nvidia/nemotron-3-super-120b-a12b:free
INTENT_MODEL_PROVIDER=onnx
INTENT_ONNX_MODEL_PATH=./packages/intent-engine/models/intent/intent_classifier.onnx
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_INTENT_MODEL=nemotron-3-nano:4b

BRAIN_PROXY_BASE_URL=http://localhost:8080
BRAIN_PROXY_AUTH_TOKEN=demo-token
# Frontend build-time API base URL (used by apps/web)
VITE_API_BASE_URL=http://127.0.0.1:8080

# --- Backend Services ---
SUPABASE_URL=your_supabase_url_here
# Use the SERVICE_ROLE key for server-side access (bypasses RLS).
# Use the ANON key for client-side Supabase SDK calls (respects RLS policies).
SUPABASE_KEY=your_supabase_service_role_key_here

TAVILY_API_KEY=your_tavily_api_key_here
INTERNAL_API_KEY=set_internal_routes_shared_secret
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id_here
# ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1

# --- Live Context Ingestion ---
# How many minutes before a weather/events snapshot is considered stale and re-fetched.
CONTEXT_REFRESH_MAX_AGE_MINUTES=60
# City to search for live weather and events.
CONTEXT_CITY=Stuttgart
